NEXT_PUBLIC_BASE_URL=https://example.com/api
VERCEL_PROTECTION_KEY=

# Optional: public site URL for metadata / OG (on Vercel, NEXT_PUBLIC_SITE_URL is recommended)
# NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app

# Optional: copy when publication API is unavailable (defaults match code fallbacks)
# NEXT_PUBLIC_DEFAULT_SITE_NAME=Vercel Daily News
# NEXT_PUBLIC_DEFAULT_HEADER_BRAND=Vercel Daily
# NEXT_PUBLIC_DEFAULT_SEO_DESCRIPTION=The latest news and insights for modern web developers.
# NEXT_PUBLIC_HOME_PAGE_DESCRIPTION=Changelogs, engineering deep dives, customer stories, and community updates from Vercel Daily.
# NEXT_PUBLIC_SEARCH_PAGE_DESCRIPTION=Search Vercel Daily articles by keyword or filter by category.
# NEXT_PUBLIC_DEV_SITE_URL=http://localhost:3000
